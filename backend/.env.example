# Copy this file to backend/.env and replace placeholder values.
# Do not commit backend/.env.

DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/green_scoring_db
SECRET_KEY=replace-with-a-long-random-secret

# Optional settings
PROJECT_NAME=Green Scoring System - CBC
VERSION=0.1.0
API_V1_PREFIX=/api/v1
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated list for pydantic list parsing
ALLOWED_ORIGINS=["http://localhost:5173"]
